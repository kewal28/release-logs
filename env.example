# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=release_log_db
# Optional pool tuning for multiple Node workers
DB_CONNECTION_LIMIT=10

# Application
PORT=3000
NODE_ENV=development
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=24h

# Public URLs (used in emails, redirects, marketing)
BASE_URL=https://yourdomain.com
DOMAIN=yourdomain.com
PROTOCOL=https

# Published docs (GitBook or other); linked from in-app /documentation
DOCS_PUBLIC_URL=
# Optional display name for public config JSON
APP_PUBLIC_NAME=Release Log
# Paid tier label on /pricing (e.g. "Contact us", "Coming soon", or a price when ready)
PRICING_PAID_LABEL=TBD

# File uploads (local disk when S3 is off)
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# SMTP — env only (not stored in database). Required for signup verification emails in production.
SMTP_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Set to false or 0 to prefer STARTTLS behavior tuned for some providers
SMTP_SECURE=true
SMTP_FROM=

# S3 / object storage — env only. When disabled, uploads use UPLOAD_PATH (not ideal for multiple app instances).
S3_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
# Optional: hostname only or full URL; see fileStorage.js
AWS_CLOUDFRONT_DOMAIN=
# Aliases (optional)
S3_BUCKET=
S3_REGION=

# Optional Redis cache (omit entirely to use MySQL only)
REDIS_URL=
# Or: REDIS_HOST=127.0.0.1 REDIS_PORT=6379 REDIS_PASSWORD=
CACHE_PUBLIC_SETTINGS_TTL=120
CACHE_CHANGELOG_LIST_TTL=60

# Rate limits (all IP-based; per process unless you add a shared store later)
DISABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_VOTE_WINDOW_MS=3600000
RATE_LIMIT_VOTE_MAX=200
RATE_LIMIT_COMMENT_WINDOW_MS=3600000
RATE_LIMIT_COMMENT_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_ADMIN_WINDOW_MS=900000
RATE_LIMIT_ADMIN_MAX=500

# Spam / comments
HONEYPOT_FIELD_NAME=_gotcha
MAX_COMMENTS_PER_IP=10
MAX_VOTES_PER_IP=50
